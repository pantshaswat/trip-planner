# Copy to .env for local dev. Never commit the real .env.
DEBUG=True
SECRET_KEY=django-insecure-dev-only-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
# Exact frontend origins allowed to call the API. In production add your Vercel
# domain, e.g. CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Regex origins (Vercel preview deploys). Defaults to any *.vercel.app.
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$

# External services (geocoding + routing). Free, key-less defaults.
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=trip-planner/1.0 (pantshaswat@gmail.com)
OSRM_URL=https://router.project-osrm.org
HTTP_TIMEOUT_SECONDS=10
